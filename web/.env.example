# Base URL the site reads JSON data from.
# After you create the repo and the data-bot has committed to /data,
# set this to the raw GitHub URL for your repo's data folder:
#
#   VITE_DATA_BASE=https://raw.githubusercontent.com/<USER>/<REPO>/main/data
#
# For local dev without GitHub you can instead copy a few JSON files into
# web/public/data/ and leave this unset (defaults to /data).
VITE_DATA_BASE=
